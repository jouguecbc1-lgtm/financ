rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'date', 'description', 'amount', 'type', 'category', 'paymentMethod', 'accountId', 'isRecurring', 'status', 'userId'])
        && data.id is string
        && data.date is string
        && data.description is string && data.description.size() <= 200
        && data.amount is number
        && data.type in ['INCOME', 'EXPENSE']
        && data.category is string
        && data.paymentMethod is string
        && data.accountId is string
        && data.isRecurring is bool
        && data.status in ['PAID', 'PENDING']
        && data.userId == request.auth.uid;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['id', 'name', 'balance', 'type', 'userId'])
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.balance is number
        && data.type in ['CHECKING', 'SAVINGS', 'INVESTMENT', 'CASH']
        && data.userId == request.auth.uid;
    }

    function isValidInvestment(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'amount', 'yield', 'startDate', 'userId'])
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.type in ['SAVINGS', 'CDB', 'TREASURY', 'STOCKS', 'FUNDS', 'CRYPTO']
        && data.amount is number
        && data.yield is number
        && data.startDate is string
        && data.userId == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['id', 'name', 'targetAmount', 'currentAmount', 'category', 'color', 'userId'])
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.targetAmount is number
        && data.currentAmount is number
        && data.category is string
        && data.color is string
        && data.userId == request.auth.uid;
    }

    function isValidCard(data) {
      return data.keys().hasAll(['id', 'name', 'lastDigits', 'limit', 'availableLimit', 'closingDay', 'dueDay', 'color', 'userId'])
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.lastDigits is string
        && data.limit is number
        && data.availableLimit is number
        && data.closingDay is number
        && data.dueDay is number
        && data.color is string
        && data.userId == request.auth.uid;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['userId', 'theme', 'currency', 'language', 'userName', 'primaryColor'])
        && data.userId == request.auth.uid
        && data.theme is string
        && data.currency is string
        && data.language is string
        && data.userName is string && data.userName.size() <= 100
        && data.primaryColor is string;
    }

    // User collection rules
    match /users/{userId} {
      allow read: if isOwner(userId);

      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(request.resource.data);
        allow update: if isOwner(userId) && isValidTransaction(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /accounts/{accountId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccount(request.resource.data);
        allow update: if isOwner(userId) && isValidAccount(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /investments/{investmentId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInvestment(request.resource.data);
        allow update: if isOwner(userId) && isValidInvestment(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(request.resource.data);
        allow update: if isOwner(userId) && isValidGoal(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /cards/{cardId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCard(request.resource.data);
        allow update: if isOwner(userId) && isValidCard(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /profile/settings {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSettings(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
